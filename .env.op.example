# 1Password CLI 用環境変数ファイル
#
# セットアップ:
#   1. 1Password に「Car Maintenance」アイテム（Secure Note 推奨）を作成
#   2. 下記と同名のフィールドを追加し、実際の値を保存
#   3. cp .env.op.example .env.op
#   4. op:// の Vault名 / アイテム名を自分の環境に合わせて編集
#   5. op signin && npm run dev
#
# 注意: このファイル名は .env.local ではなく .env.op です。
#       Next.js が op:// 文字列をそのまま読み込むのを防ぐためです。
#       DATABASE_URL は不要（DB_* から自動組み立て）。
#       開発 DB 接続先（127.0.0.1:3306）はコード固定。1Password 不要。

# Vault: Private / Item: Car Maintenance

# Database
# 開発: 127.0.0.1:3306 固定 / 本番: DB_HOST + DB_PORT
DB_USER=op://Private/Car Maintenance/DB_USER
DB_PASSWORD=op://Private/Car Maintenance/DB_PASSWORD
DB_NAME=op://Private/Car Maintenance/DB_NAME
DB_HOST=op://Private/Car Maintenance/DB_HOST
DB_PORT=op://Private/Car Maintenance/DB_PORT

# Auth URL（開発: AUTH_URL_DEV、本番: AUTH_URL）
AUTH_URL=op://Private/Car Maintenance/AUTH_URL
AUTH_URL_DEV=op://Private/Car Maintenance/AUTH_URL_DEV
AUTH_SECRET=op://Private/Car Maintenance/AUTH_SECRET
GOOGLE_CLIENT_ID=op://Private/Car Maintenance/GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=op://Private/Car Maintenance/GOOGLE_CLIENT_SECRET
ALLOWED_EMAIL=op://Private/Car Maintenance/ALLOWED_EMAIL
DISCORD_WEBHOOK_SIGNUP_URL=op://Private/Car Maintenance/DISCORD_WEBHOOK_SIGNUP_URL
DISCORD_WEBHOOK_LOGIN_URL=op://Private/Car Maintenance/DISCORD_WEBHOOK_LOGIN_URL

# 本番 DB 確認（開発環境から SSH トンネル経由で接続する場合）
# VPS の MySQL が localhost のみ待受のときに使用。直結できる場合は不要。
SSH_HOST=op://Private/Car Maintenance/SSH_HOST
SSH_USER=op://Private/Car Maintenance/SSH_USER
SSH_PORT=op://Private/Car Maintenance/SSH_PORT
