{
  "name": "car",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "bash scripts/with-op-env.sh sh -c 'prisma generate && next build'",
    "build:ci": "prisma generate && next build",
    "start": "bash scripts/with-op-env.sh next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "env:init": "cp -n .env.op.example .env.op && echo 'Created .env.op — edit op:// paths, then run: op signin && npm run dev'",
    "env:check": "bash scripts/with-op-env.sh bash scripts/env-check.sh",
    "db:generate": "prisma generate",
    "db:check": "bash scripts/with-op-env.sh npx tsx scripts/db-check.ts",
    "db:setup": "bash scripts/setup-db.sh",
    "db:migrate": "bash scripts/with-op-env.sh prisma migrate deploy",
    "db:migrate:dev": "bash scripts/with-op-env.sh prisma migrate dev",
    "db:migrate:fix": "bash scripts/with-op-env.sh prisma migrate resolve --rolled-back 20250621000000_init",
    "db:migrate:resolve": "bash scripts/with-op-env.sh prisma migrate resolve",
    "db:deploy": "bash scripts/with-op-env.sh prisma migrate deploy",
    "db:studio": "bash scripts/with-op-env.sh prisma studio",
    "db:check:prod": "bash scripts/with-op-prod-db.sh npx tsx scripts/db-check.ts",
    "db:studio:prod": "bash scripts/with-op-prod-db.sh prisma studio",
    "db:tunnel:prod": "bash scripts/prod-db-tunnel.sh",
    "db:check:prod:tunnel": "DB_TUNNEL=true bash scripts/with-op-prod-db.sh npx tsx scripts/db-check.ts",
    "db:studio:prod:tunnel": "DB_TUNNEL=true bash scripts/with-op-prod-db.sh prisma studio",
    "dev:prod-db": "bash scripts/dev-prod-db.sh",
    "dev:prod-db:tunnel": "DB_TUNNEL=true bash scripts/dev-prod-db.sh"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
